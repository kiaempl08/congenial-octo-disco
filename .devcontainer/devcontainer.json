{
  "name": "Ubuntu Systemd VM",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--privileged",
    "--init",
    "--device=/dev/fuse",
    "--shm-size=8gb"
  ],
  "mounts": [
    "source=/sys/fs/cgroup,target=/sys/fs/cgroup,type=bind"
  ],
  "overrideCommand": false,
  "remoteUser": "root",
  "postCreateCommand": "systemctl start ssh",
  "customizations": {
    "vscode": {
      "extensions": []
    }
  }
}
